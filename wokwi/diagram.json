{
  "version": 1,
  "author": "ThermoSense",
  "editor": "wokwi",
  "parts": [
    {
      "type": "wokwi-esp32-devkit-v1",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-dht22",
      "id": "dht1",
      "top": -80,
      "left": 220,
      "attrs": { "temperature": "28.5", "humidity": "62" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": -20,
      "left": 190,
      "attrs": { "value": "10000" },
      "rotate": 90
    },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 80,
      "left": 230,
      "attrs": { "color": "cyan" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r2",
      "top": 112,
      "left": 190,
      "attrs": { "value": "220" },
      "rotate": 90
    }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", "", []],
    ["esp:RX", "$serialMonitor:TX", "", []],

    ["dht1:VCC", "esp:3V3", "red", []],
    ["dht1:GND", "esp:GND.1", "black", []],
    ["dht1:SDA", "esp:15", "green", []],

    ["r1:1", "esp:3V3", "red", []],
    ["r1:2", "esp:15", "green", []],

    ["esp:2", "r2:1", "cyan", []],
    ["r2:2", "led1:A", "cyan", []],
    ["led1:K", "esp:GND.2", "black", []]
  ],
  "dependencies": {}
}
